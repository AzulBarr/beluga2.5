#!/usr/bin/env python3
import os
import subprocess
import sys

def main():
    perf_data = "perf.data"
    flamegraph_dir = "/opt/FlameGraph"
    
    if not os.path.exists(perf_data):
        print(f"Error: File '{perf_data}' not found.")
        print("Please ensure the profiling command has been executed first.")
        sys.exit(1)

    if not os.path.exists(flamegraph_dir):
        print(f"Error: FlameGraph tools not found in {flamegraph_dir}")
        print("Install them using: git clone https://github.com/brendangregg/FlameGraph.git ~")
        sys.exit(1)

    print("--- Generating FlameGraph (this may take a while) ---")

    try:
        print("[1/3] Extracting perf data...")
        with open("out.perf", "w") as out_perf:
            subprocess.run(["perf", "script", "-i", perf_data], stdout=out_perf, check=True)

        print("[2/3] Collapsing stacks...")
        with open("out.folded", "w") as out_folded:
            subprocess.run([os.path.join(flamegraph_dir, "stackcollapse-perf.pl"), "out.perf"], 
                           stdout=out_folded, check=True)

        print("[3/3] Generating SVG image...")
        with open("flamegraph.svg", "w") as out_svg:
            subprocess.run([os.path.join(flamegraph_dir, "flamegraph.pl"), "out.folded"], 
                           stdout=out_svg, check=True)

        os.remove("out.perf")
        os.remove("out.folded")

        print(f"\n--- [SUCCESS] FlameGraph generated: {os.getcwd()}/flamegraph.svg ---")
        print("Open it with your web browser (Firefox/Chrome) to view the results.")

    except subprocess.CalledProcessError as e:
        print(f"Error during processing: {e}")
    except Exception as e:
        print(f"Unexpected error: {e}")

if __name__ == '__main__':
    main()